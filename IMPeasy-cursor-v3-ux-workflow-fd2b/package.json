{
  "name": "impeasy",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "seed:admin": "node scripts/seed-admin-operator.mjs",
    "seed:mvp-010-users": "node scripts/seed-mvp-010-users.mjs",
    "seed:mvp-020-demo": "node scripts/seed-mvp-020-demo.mjs",
    "seed:mvp-030-demo": "node scripts/seed-mvp-030-demo.mjs",
    "seed:kiosk-ready": "node scripts/seed-kiosk-ready.mjs",
    "seed:mvp-040-demo": "node scripts/seed-mvp-040-demo.mjs",
    "seed:all": "npm run seed:admin && npm run seed:mvp-010-users && npm run seed:mvp-020-demo && npm run seed:mvp-030-demo && npm run seed:kiosk-ready && npm run seed:mvp-040-demo",
    "start:sandbox": "bash scripts/start-sandbox.sh",
    "test:api": "npm --workspace @impeasy/api run test",
    "test:web": "npm --workspace @impeasy/web run test"
  }
}
